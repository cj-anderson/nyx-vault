{
  "manifest_version": 2,
  "name": "Nyx",
  "version": "1.0",
  "description": "Local encrypted notes and password vault",

  "sidebar_action": {
    "default_title": "Nyx",
    "default_panel": "popup.html",
    "open_at_install": true
  },
  "permissions": ["storage"],
  "icons": {
  "16": "icons/icon16.png",
  "48": "icons/icon48.png",
  "128": "icons/icon128.png"
}
}